{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "isolatedModules": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": [
    ".erb/scripts/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude": [
    "release/build",
    "release/app/dist",
    ".erb/dll",
    "node_modules"
  ]
}
